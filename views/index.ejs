<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student List App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- Bootstrap Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h2 class="text-center mb-4">Students from Student List App Database</h2>

        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Student Image</th>
                    <th>Dob</th>
                    <th>Contact</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i = 0; i < students.length; i++) { %>
                <tr>
                    <td><a href="/student/<%= students[i].studentId %>"><%= students[i].name %></a></td>
                    <td><img src="<%= students[i].image %>" width="60"></td>
                    <td><%= new Date(students[i].dob).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %></td>
                    <td><%= students[i].contact %></td>
                    <td>
                        <a href="/student/<%= students[i].studentId %>/edit" class="btn btn-sm btn-secondary">Edit</a>
                        <form action="/student/<%= students[i].studentId %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this student?');">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>

</body>
</html>
