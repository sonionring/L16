<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- Bootstrap Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h2>Student Details</h2>

        <% if (student) { %>
            <div class="card shadow-sm p-4 col-md-8">
                <p><b>Student Name:</b><br><%= student.name %></p>
                <p><b>Student Image:</b><br>
                    <% if (student.image) { %>
                        <img src="<%= student.image %>" alt="<%= student.name %>" width="150" class="rounded mt-2">
                    <% } else { %>
                        <span class="text-muted">No image uploaded</span>
                    <% } %>
                </p>
                <p><b>Date of Birth:</b><br><%= new Date(student.dob).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %></p>
                <p><b>Contact:</b><br><%= student.contact %></p>
                <p>
                    <a href="/student/<%= student.studentId %>/edit" class="btn btn-secondary me-2">Edit</a>
                    <form action="/student/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this student?');">
                        <input type="hidden" name="studentId" value="<%= student.studentId %>">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </p>
            </div>
        <% } else { %>
            <p>No student found.</p>
        <% } %>
    </div>

</body>
</html>
