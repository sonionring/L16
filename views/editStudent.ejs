<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- Bootstrap Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h2 class="text-center mb-4">Edit Student</h2>

        <% if (student) { %>
        <form action="/student/<%= student.studentId %>/edit" method="POST" enctype="multipart/form-data" class="col-md-6 mx-auto">
            <input type="hidden" name="existingImage" value="<%= student.image || '' %>">
            <div class="mb-3">
                <label for="name" class="form-label">Student Name:</label>
                <input type="text" class="form-control" id="name" name="name" value="<%= student.name %>" required>
            </div>

            <div class="mb-3">
                <label for="dob" class="form-label">D.o.B:</label>
                <input type="date" class="form-control" id="dob" name="dob" value="<%= new Date(student.dob).toISOString().slice(0,10) %>" required>
            </div>

            <div class="mb-3">
                <label for="contact" class="form-label">Contact:</label>
                <input type="text" class="form-control" id="contact" name="contact" value="<%= student.contact %>" required>
            </div>

            <div class="mb-3">
                <label for="imageFile" class="form-label">Upload new photo:</label>
                <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*">
            </div>

            <div class="mb-3">
                <label for="image" class="form-label">Or use image URL:</label>
                <input type="text" class="form-control" id="image" name="image" value="<%= student.image || '' %>">
            </div>

            <% if (student.image) { %>
                <div class="mb-3">
                    <label class="form-label">Current Photo:</label><br>
                    <img src="<%= student.image %>" alt="Current photo" width="120" class="rounded">
                </div>
            <% } %>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/student/<%= student.studentId %>" class="btn btn-secondary">Cancel</a>
        </form>
        <% } else { %>
            <p>No student found.</p>
        <% } %>
    </div>

</body>
</html>
